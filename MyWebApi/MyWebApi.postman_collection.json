    {
      "name": "Interview",
      "item": [
        {
          "name": "Generate Questions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/interview/questions?role=.NET%20Developer&count=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "interview",
                "questions"
              ],
              "query": [
                {
                  "key": "role",
                  "value": ".NET Developer"
                },
                {
                  "key": "count",
                  "value": "5"
                }
              ]
            },
            "description": "Generate interview questions by role; creates interview session."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Session id is returned', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('sessionId');",
                  "  pm.collectionVariables.set('sessionId', body.sessionId);",
                  "  if (body.questions && body.questions.length > 0) {",
                  "    pm.collectionVariables.set('lastQuestion', body.questions[0]);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
